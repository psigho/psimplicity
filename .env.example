# ============================================
# Psimplicity — AI Script → Image Pipeline
# Environment Variables
# ============================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# You need AT LEAST one LLM key for parsing & critique.
# Gemini alone covers everything (parser + critic + images).
# ============================================

# --- RECOMMENDED: Gemini API Key ---
# Powers: Parser, Critic, AND Image Generation (Nano Banana Pro)
# Get yours free: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- OPTIONAL: Direct OpenAI ---
# Powers: Parser & Critic (GPT-4.1 Mini) + DALL-E 3 images
# Get yours: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- OPTIONAL: OpenRouter (100+ models) ---
# Powers: Parser & Critic via Claude, DeepSeek, Qwen, Gemini Pro, etc.
# Get yours: https://openrouter.ai/keys
OPENROUTER_API_KEY=
